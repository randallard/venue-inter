# ── OIDC (Authentik) ──────────────────────────────────────────────────────────
# Local dev defaults match the values set by the Authentik blueprint.
# In production, replace all four with your deployment's values.
OIDC_ISSUER_URL=https://your-authentik-host/application/o/your-slug/
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
# OIDC_CA_CERT_PATH=config/ssl/your-ca-cert.pem  # only needed for self-signed IdP cert

INFORMIX_DSN=venueinter_dev
INFORMIX_USER=informix
INFORMIX_PASSWORD=in4mix
APP_PORT=8080
RUST_LOG=info,audit=info

# Application Postgres (tasks, tickets, status reviews, session store)
DATABASE_URL=postgres://venueinter:venueinter-dev-password@localhost:5433/venueinter
VENUEINTER_DB_PASS=venueinter-dev-password

# Cookie security
# Set to false ONLY for local HTTP dev — must be true (or absent) in production.
# When true, uses __Host- cookie prefix (requires HTTPS).
COOKIE_SECURE=false

# Email (optional — leave SMTP_HOST empty to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
SMTP_FROM=noreply@localhost
SYSADMIN_EMAIL=admin@localhost

# ── WebDAV document cache (national system file server) ──────────────────────
# Leave WEBDAV_BASE_URL empty to disable document caching entirely.
WEBDAV_BASE_URL=https://your-webdav-host/path/to/root
WEBDAV_USER=your-webdav-user
WEBDAV_PASSWORD=your-webdav-password

# ── E2E / Puppeteer test credentials ─────────────────────────────────────────
# These are NOT read by the app — they are only used by `pnpm test:e2e`.
# With the Docker Compose stack these match the dev users created by the
# Authentik blueprint (authentik-blueprints/venue-inter-oauth2.yaml).
#
# TEST_URL defaults to http://localhost:5173 when unset.
# CEO_TEST_USER / CEO_TEST_PASSWORD are optional — CEO-specific tests are
# skipped when absent.
#
# TEST_URL=http://localhost:5173
# TEST_USER=devuser
# TEST_PASSWORD=dev-password
# CEO_TEST_USER=ceouser
# CEO_TEST_PASSWORD=dev-password
