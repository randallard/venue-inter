OIDC_ISSUER_URL=https://your-authentik-host/application/o/your-slug/
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=http://localhost:8080/auth/callback
# OIDC_CA_CERT_PATH=config/ssl/your-ca-cert.pem  # only needed for self-signed IdP cert

INFORMIX_DSN=venueinter_dev
INFORMIX_USER=informix
INFORMIX_PASSWORD=in4mix
APP_PORT=8080
RUST_LOG=info,audit=info

# Application Postgres (tasks, tickets, status reviews, session store)
DATABASE_URL=postgres://venueinter:venueinter-dev-password@localhost:5433/venueinter
VENUEINTER_DB_PASS=venueinter-dev-password

# Cookie security
# Set to false ONLY for local HTTP dev — must be true (or absent) in production.
# When true, uses __Host- cookie prefix (requires HTTPS).
COOKIE_SECURE=false

# Email (optional — leave SMTP_HOST empty to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
SMTP_FROM=noreply@localhost
SYSADMIN_EMAIL=admin@localhost
